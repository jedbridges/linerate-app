{
  "$schema": "https://schemas.designtokens.org/0.0.0/schema.json",
  "$description": "LineRate design tokens, Brand v3. Platform-agnostic source of truth in W3C Design Tokens format. Transform with Style Dictionary or similar to generate platform-specific outputs. Dark-first canonical surface; light mode is the inverse.",

  "color": {
    "brand": {
      "onyx":     { "$type": "color", "$value": "#101010", "$description": "Primary surface. Near-black, dominant tone of the brand." },
      "paper":    { "$type": "color", "$value": "#FFFFFF", "$description": "Inverse / primary text on dark surface. Pure white." },
      "chalk":    { "$type": "color", "$value": "#E5E5E5", "$description": "Light fill, top of the neutral ramp on light surfaces." },
      "graphite": { "$type": "color", "$value": "#838383", "$description": "Mid gray, muted text, supporting tone." },
      "amber":    { "$type": "color", "$value": "#DF8E2A", "$description": "Single accent color. Used very rarely: brand accent line, status pending, occasional inline emphasis. Never a primary CTA." }
    },

    "neutral": {
      "$description": "Neutral ramp derived from Onyx and Paper. Cool, near-perfect grayscale.",
      "0":   { "$type": "color", "$value": "#FFFFFF", "$description": "Paper" },
      "50":  { "$type": "color", "$value": "#FAFAFA" },
      "100": { "$type": "color", "$value": "#F4F4F4" },
      "200": { "$type": "color", "$value": "#E5E5E5", "$description": "Chalk" },
      "300": { "$type": "color", "$value": "#D4D4D4" },
      "400": { "$type": "color", "$value": "#A3A3A3" },
      "500": { "$type": "color", "$value": "#838383", "$description": "Graphite" },
      "600": { "$type": "color", "$value": "#5C5C5C" },
      "700": { "$type": "color", "$value": "#3F3F3F" },
      "800": { "$type": "color", "$value": "#262626" },
      "900": { "$type": "color", "$value": "#1A1A1A" },
      "950": { "$type": "color", "$value": "#101010", "$description": "Onyx" }
    },

    "amber": {
      "$description": "Amber ramp derived from #DF8E2A. Used very rarely. Status pending and occasional brand accents only.",
      "50":  { "$type": "color", "$value": "#FBF1E3" },
      "100": { "$type": "color", "$value": "#F4DCB1" },
      "200": { "$type": "color", "$value": "#EDC684" },
      "300": { "$type": "color", "$value": "#E7AF52" },
      "400": { "$type": "color", "$value": "#E29A35" },
      "500": { "$type": "color", "$value": "#DF8E2A", "$description": "Amber, brand signal color" },
      "600": { "$type": "color", "$value": "#B07120" },
      "700": { "$type": "color", "$value": "#84551A" },
      "800": { "$type": "color", "$value": "#5A3B12" },
      "900": { "$type": "color", "$value": "#392408" },
      "950": { "$type": "color", "$value": "#1F1404" }
    },

    "success": {
      "$description": "Brand-tone success. Desaturated forest green that reads as graphite-tinted, harmonious with the v3 palette. Status only, never decorative.",
      "50":  { "$type": "color", "$value": "#E8EDE6" },
      "100": { "$type": "color", "$value": "#C9D3C3" },
      "500": { "$type": "color", "$value": "#6B7A5C" },
      "600": { "$type": "color", "$value": "#525E47" },
      "700": { "$type": "color", "$value": "#3A4232" }
    },

    "danger": {
      "$description": "Brand-tone danger. Muted brick that reads as graphite-tinted warm, sits beside Amber without clashing.",
      "50":  { "$type": "color", "$value": "#F2E4E1" },
      "100": { "$type": "color", "$value": "#E3BFB9" },
      "500": { "$type": "color", "$value": "#9C5650" },
      "600": { "$type": "color", "$value": "#7A4039" },
      "700": { "$type": "color", "$value": "#582C27" }
    }
  },

  "semantic": {
    "$description": "Role-based tokens. Components reference these, never raw scale values. Dark is the canonical default; light is the inverse.",

    "dark": {
      "$description": "Canonical surface. Page = Onyx, text = Paper. This is what the brand book renders.",
      "background": {
        "page":     { "$type": "color", "$value": "{color.neutral.950}", "$description": "Page background. Onyx." },
        "surface":  { "$type": "color", "$value": "{color.neutral.900}", "$description": "Cards, elevated panels. One step above page." },
        "raised":   { "$type": "color", "$value": "{color.neutral.800}", "$description": "Modals, popovers, dropdowns." },
        "muted":    { "$type": "color", "$value": "{color.neutral.800}", "$description": "Subtle fills, hover states." },
        "inverse":  { "$type": "color", "$value": "{color.neutral.0}",   "$description": "Light section on a dark page." }
      },
      "foreground": {
        "default":  { "$type": "color", "$value": "{color.neutral.0}",   "$description": "Primary text. Paper." },
        "muted":    { "$type": "color", "$value": "{color.neutral.400}", "$description": "Secondary text, labels." },
        "subtle":   { "$type": "color", "$value": "{color.neutral.500}", "$description": "Tertiary text, captions, metadata. Graphite." },
        "disabled": { "$type": "color", "$value": "{color.neutral.600}" },
        "inverse":  { "$type": "color", "$value": "{color.neutral.950}", "$description": "Text on inverse / light surfaces." }
      },
      "border": {
        "default":  { "$type": "color", "$value": "{color.neutral.800}" },
        "strong":   { "$type": "color", "$value": "{color.neutral.700}" },
        "subtle":   { "$type": "color", "$value": "{color.neutral.900}" }
      },
      "primary": {
        "$description": "Primary CTA. On dark, primary is Paper on Onyx.",
        "default":    { "$type": "color", "$value": "{color.neutral.0}"   },
        "hover":      { "$type": "color", "$value": "{color.neutral.100}" },
        "active":     { "$type": "color", "$value": "{color.neutral.200}" },
        "foreground": { "$type": "color", "$value": "{color.neutral.950}" }
      },
      "accent": {
        "$description": "Amber. Used very rarely. Brand accent line, status pending, key marketing moments only.",
        "default":    { "$type": "color", "$value": "{color.amber.500}" },
        "hover":      { "$type": "color", "$value": "{color.amber.400}" },
        "surface":    { "$type": "color", "$value": "{color.amber.900}" },
        "foreground": { "$type": "color", "$value": "{color.amber.300}" },
        "on-color":   { "$type": "color", "$value": "{color.neutral.950}" }
      },
      "status": {
        "success-surface":    { "$type": "color", "$value": "{color.success.700}" },
        "success-foreground": { "$type": "color", "$value": "{color.success.100}" },
        "danger-surface":     { "$type": "color", "$value": "{color.danger.700}"  },
        "danger-foreground":  { "$type": "color", "$value": "{color.danger.100}"  },
        "pending-surface":    { "$type": "color", "$value": "{color.amber.900}"   },
        "pending-foreground": { "$type": "color", "$value": "{color.amber.200}"   }
      },
      "ring": { "$type": "color", "$value": "rgba(255, 255, 255, 0.18)", "$description": "Focus ring. Paper at low opacity on dark." }
    },

    "light": {
      "$description": "Inverse of dark. Shipped for accessibility, reading-heavy product screens, and the explicit light toggle. Brand canonical is dark.",
      "background": {
        "page":     { "$type": "color", "$value": "{color.neutral.0}",   "$description": "Page background. Paper." },
        "surface":  { "$type": "color", "$value": "{color.neutral.50}"  },
        "raised":   { "$type": "color", "$value": "{color.neutral.0}"   },
        "muted":    { "$type": "color", "$value": "{color.neutral.100}" },
        "inverse":  { "$type": "color", "$value": "{color.neutral.950}" }
      },
      "foreground": {
        "default":  { "$type": "color", "$value": "{color.neutral.950}", "$description": "Primary text. Onyx." },
        "muted":    { "$type": "color", "$value": "{color.neutral.700}" },
        "subtle":   { "$type": "color", "$value": "{color.neutral.500}", "$description": "Graphite." },
        "disabled": { "$type": "color", "$value": "{color.neutral.400}" },
        "inverse":  { "$type": "color", "$value": "{color.neutral.0}" }
      },
      "border": {
        "default":  { "$type": "color", "$value": "{color.neutral.200}" },
        "strong":   { "$type": "color", "$value": "{color.neutral.300}" },
        "subtle":   { "$type": "color", "$value": "{color.neutral.100}" }
      },
      "primary": {
        "default":    { "$type": "color", "$value": "{color.neutral.950}" },
        "hover":      { "$type": "color", "$value": "{color.neutral.900}" },
        "active":     { "$type": "color", "$value": "{color.neutral.800}" },
        "foreground": { "$type": "color", "$value": "{color.neutral.0}"   }
      },
      "accent": {
        "default":    { "$type": "color", "$value": "{color.amber.500}" },
        "hover":      { "$type": "color", "$value": "{color.amber.600}" },
        "surface":    { "$type": "color", "$value": "{color.amber.50}"  },
        "foreground": { "$type": "color", "$value": "{color.amber.700}" },
        "on-color":   { "$type": "color", "$value": "{color.neutral.0}" }
      },
      "status": {
        "success-surface":    { "$type": "color", "$value": "{color.success.50}"  },
        "success-foreground": { "$type": "color", "$value": "{color.success.700}" },
        "danger-surface":     { "$type": "color", "$value": "{color.danger.50}"   },
        "danger-foreground":  { "$type": "color", "$value": "{color.danger.700}"  },
        "pending-surface":    { "$type": "color", "$value": "{color.amber.50}"    },
        "pending-foreground": { "$type": "color", "$value": "{color.amber.700}"   }
      },
      "ring": { "$type": "color", "$value": "rgba(16, 16, 16, 0.20)", "$description": "Focus ring. Onyx at low opacity on light." }
    }
  },

  "typography": {
    "family": {
      "sans": { "$type": "fontFamily", "$value": ["General Sans", "system-ui", "-apple-system", "Segoe UI", "sans-serif"], "$description": "The voice of the brand. Headings, body, marketing, legal. Self-hosted from Fontshare." },
      "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "SFMono-Regular", "Menlo", "monospace"], "$description": "The voice of the ledger. Settlement amounts, transaction IDs, timestamps, hashes, account references." }
    },
    "weight": {
      "regular":  { "$type": "fontWeight", "$value": 400 },
      "medium":   { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600, "$description": "Display headings and the wordmark only." }
    },
    "size": {
      "$description": "Rem-based so the system scales with user font preferences and browser zoom. Sizes assume a 16px root: 0.6875rem = 11px, 1rem = 16px, etc.",
      "xs":   { "$type": "dimension", "$value": "0.6875rem" },
      "sm":   { "$type": "dimension", "$value": "0.8125rem" },
      "base": { "$type": "dimension", "$value": "1rem", "$description": "Default body. 16px equivalent, the WCAG readability floor. Tighten density via tracking-tight and snug leading where appropriate." },
      "md":   { "$type": "dimension", "$value": "1.0625rem", "$description": "Comfortable reading size (17px), a notch above body for long-form prose." },
      "lg":   { "$type": "dimension", "$value": "1.125rem" },
      "xl":   { "$type": "dimension", "$value": "1.25rem" },
      "2xl":  { "$type": "dimension", "$value": "1.5rem" },
      "3xl":  { "$type": "dimension", "$value": "1.875rem" },
      "4xl":  { "$type": "dimension", "$value": "2.25rem" },
      "5xl":  { "$type": "dimension", "$value": "3rem" },
      "6xl":  { "$type": "dimension", "$value": "4rem" },
      "7xl":  { "$type": "dimension", "$value": "5rem" },
      "8xl":  { "$type": "dimension", "$value": "6rem" }
    },
    "display": {
      "$description": "Fluid display sizes for marketing surfaces (Hero, big section heads). Clamp scales smoothly with viewport instead of jumping at breakpoints. Product UI keeps the fixed rem scale above for predictable density.",
      "sm": { "$type": "dimension", "$value": "clamp(1.875rem, 1.25rem + 2.5vw, 3rem)", "$description": "Section heads in marketing, ~30 to 48px." },
      "md": { "$type": "dimension", "$value": "clamp(2.25rem, 1.25rem + 4vw, 4rem)",   "$description": "Mid hero, ~36 to 64px." },
      "lg": { "$type": "dimension", "$value": "clamp(3rem, 1.25rem + 6vw, 5rem)",      "$description": "Hero display, ~48 to 80px." }
    },
    "tracking": {
      "tight":   { "$type": "dimension", "$value": "-0.02em",  "$description": "Display headings." },
      "snug":    { "$type": "dimension", "$value": "-0.01em",  "$description": "Mid headings, mono numerals at display size." },
      "normal":  { "$type": "dimension", "$value": "0" },
      "wide":    { "$type": "dimension", "$value": "0.08em",   "$description": "Eyebrows, small caps." },
      "widest":  { "$type": "dimension", "$value": "0.14em",   "$description": "Mono eyebrows, system labels, wordmark." }
    },
    "leading": {
      "tight":   { "$type": "number", "$value": 1.05, "$description": "Display." },
      "snug":    { "$type": "number", "$value": 1.2 },
      "normal":  { "$type": "number", "$value": 1.5, "$description": "Body default." },
      "relaxed": { "$type": "number", "$value": 1.65 }
    }
  },

  "space": {
    "0":   { "$type": "dimension", "$value": "0" },
    "0.5": { "$type": "dimension", "$value": "2px" },
    "1":   { "$type": "dimension", "$value": "4px" },
    "1.5": { "$type": "dimension", "$value": "6px" },
    "2":   { "$type": "dimension", "$value": "8px" },
    "3":   { "$type": "dimension", "$value": "12px" },
    "4":   { "$type": "dimension", "$value": "16px" },
    "5":   { "$type": "dimension", "$value": "20px" },
    "6":   { "$type": "dimension", "$value": "24px" },
    "8":   { "$type": "dimension", "$value": "32px" },
    "10":  { "$type": "dimension", "$value": "40px" },
    "12":  { "$type": "dimension", "$value": "48px" },
    "16":  { "$type": "dimension", "$value": "64px" },
    "20":  { "$type": "dimension", "$value": "80px" },
    "24":  { "$type": "dimension", "$value": "96px" },
    "32":  { "$type": "dimension", "$value": "128px" }
  },

  "radius": {
    "none": { "$type": "dimension", "$value": "0" },
    "xs":   { "$type": "dimension", "$value": "2px" },
    "sm":   { "$type": "dimension", "$value": "4px" },
    "md":   { "$type": "dimension", "$value": "6px" },
    "lg":   { "$type": "dimension", "$value": "8px" },
    "xl":   { "$type": "dimension", "$value": "12px" },
    "2xl":  { "$type": "dimension", "$value": "16px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },

  "shadow": {
    "$description": "Mostly flat on dark; tonal lift via background-color, not shadow. Reserved values for floating menus and modals.",
    "none": { "$type": "shadow", "$value": "none" },
    "sm":   { "$type": "shadow", "$value": "0 1px 0 0 rgba(0, 0, 0, 0.04)" },
    "md":   { "$type": "shadow", "$value": "0 1px 2px rgba(0, 0, 0, 0.20), 0 0 0 0.5px rgba(0, 0, 0, 0.30)" },
    "lg":   { "$type": "shadow", "$value": "0 8px 24px rgba(0, 0, 0, 0.30), 0 0 0 0.5px rgba(0, 0, 0, 0.30)" }
  },

  "motion": {
    "duration": {
      "fast":   { "$type": "duration", "$value": "120ms" },
      "normal": { "$type": "duration", "$value": "200ms" },
      "slow":   { "$type": "duration", "$value": "320ms" }
    },
    "easing": {
      "default": { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] },
      "in":      { "$type": "cubicBezier", "$value": [0.4, 0, 1, 1] },
      "out":     { "$type": "cubicBezier", "$value": [0, 0, 0.2, 1] }
    }
  }
}
