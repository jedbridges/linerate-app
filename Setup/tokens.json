{
  "$schema": "https://schemas.designtokens.org/0.0.0/schema.json",
  "$description": "LineRate design tokens. Platform-agnostic source of truth in W3C Design Tokens format. Transform with Style Dictionary or similar to generate platform-specific outputs.",

  "color": {
    "brand": {
      "ink":       { "$type": "color", "$value": "#14151A", "$description": "Primary text and high-contrast surfaces. The darkest tone." },
      "bone":      { "$type": "color", "$value": "#F2EFE9", "$description": "Default page background. Warm off-white." },
      "parchment": { "$type": "color", "$value": "#C2C0BD", "$description": "Borders, dividers, low-emphasis surfaces." },
      "amber":     { "$type": "color", "$value": "#BE7818", "$description": "Signal color. Never used as primary CTA. Reserved for accents, status, and key marketing moments." }
    },

    "neutral": {
      "0":   { "$type": "color", "$value": "#FFFFFF" },
      "50":  { "$type": "color", "$value": "#FAF8F4" },
      "100": { "$type": "color", "$value": "#F2EFE9", "$description": "Bone" },
      "200": { "$type": "color", "$value": "#E6E3DC" },
      "300": { "$type": "color", "$value": "#D4D1CB" },
      "400": { "$type": "color", "$value": "#C2C0BD", "$description": "Parchment" },
      "500": { "$type": "color", "$value": "#9F9D9A" },
      "600": { "$type": "color", "$value": "#7C7A77" },
      "700": { "$type": "color", "$value": "#5A5957" },
      "800": { "$type": "color", "$value": "#3F3E40" },
      "900": { "$type": "color", "$value": "#1F2024" },
      "950": { "$type": "color", "$value": "#14151A", "$description": "Ink" }
    },

    "amber": {
      "50":  { "$type": "color", "$value": "#FCF4E5" },
      "100": { "$type": "color", "$value": "#F8E3B9" },
      "200": { "$type": "color", "$value": "#F3CC80" },
      "300": { "$type": "color", "$value": "#E8B14C" },
      "400": { "$type": "color", "$value": "#D29128" },
      "500": { "$type": "color", "$value": "#BE7818", "$description": "Amber, brand signal color" },
      "600": { "$type": "color", "$value": "#9E6213" },
      "700": { "$type": "color", "$value": "#7B4D10" },
      "800": { "$type": "color", "$value": "#5A380C" },
      "900": { "$type": "color", "$value": "#3D2607" },
      "950": { "$type": "color", "$value": "#261805" }
    },

    "success": {
      "$description": "Muted forest green. Used for settled/cleared status only. Never decorative.",
      "50":  { "$type": "color", "$value": "#EAF1EC" },
      "100": { "$type": "color", "$value": "#CBDFD0" },
      "500": { "$type": "color", "$value": "#3D7A57" },
      "600": { "$type": "color", "$value": "#2F6244" },
      "700": { "$type": "color", "$value": "#244B34" }
    },

    "danger": {
      "$description": "Muted brick red. Failed settlements, breaks, audit exceptions. Warm-biased to fit the palette.",
      "50":  { "$type": "color", "$value": "#F7E8E5" },
      "100": { "$type": "color", "$value": "#EFC9C3" },
      "500": { "$type": "color", "$value": "#B33F33" },
      "600": { "$type": "color", "$value": "#8E2D24" },
      "700": { "$type": "color", "$value": "#6B1F18" }
    }
  },

  "semantic": {
    "$description": "Role-based tokens. Components should reference these, never raw scale values.",

    "light": {
      "background": {
        "page":     { "$type": "color", "$value": "{color.neutral.100}", "$description": "Page background. Bone." },
        "surface":  { "$type": "color", "$value": "{color.neutral.50}",  "$description": "Cards, elevated panels. Lighter than the page." },
        "raised":   { "$type": "color", "$value": "{color.neutral.0}",   "$description": "Modals, popovers." },
        "muted":    { "$type": "color", "$value": "{color.neutral.200}", "$description": "Subtle fills, hover states." },
        "inverse":  { "$type": "color", "$value": "{color.neutral.950}", "$description": "Dark sections on a light page." }
      },
      "foreground": {
        "default":  { "$type": "color", "$value": "{color.neutral.950}", "$description": "Primary text." },
        "muted":    { "$type": "color", "$value": "{color.neutral.700}", "$description": "Secondary text, labels." },
        "subtle":   { "$type": "color", "$value": "{color.neutral.600}", "$description": "Tertiary text, captions, metadata." },
        "disabled": { "$type": "color", "$value": "{color.neutral.500}" },
        "inverse":  { "$type": "color", "$value": "{color.neutral.100}", "$description": "Text on inverse / dark surfaces." }
      },
      "border": {
        "default":  { "$type": "color", "$value": "{color.neutral.300}" },
        "strong":   { "$type": "color", "$value": "{color.neutral.400}" },
        "subtle":   { "$type": "color", "$value": "{color.neutral.200}" }
      },
      "primary": {
        "$description": "Primary CTA. Always Ink. Never Amber.",
        "default":    { "$type": "color", "$value": "{color.neutral.950}" },
        "hover":      { "$type": "color", "$value": "{color.neutral.900}" },
        "active":     { "$type": "color", "$value": "{color.neutral.800}" },
        "foreground": { "$type": "color", "$value": "{color.neutral.100}" }
      },
      "accent": {
        "$description": "Amber. Status emphasis, marketing accents, key moments only.",
        "default":    { "$type": "color", "$value": "{color.amber.500}" },
        "hover":      { "$type": "color", "$value": "{color.amber.600}" },
        "surface":    { "$type": "color", "$value": "{color.amber.50}" },
        "foreground": { "$type": "color", "$value": "{color.amber.700}", "$description": "Text on amber surface tint." },
        "on-color":   { "$type": "color", "$value": "{color.neutral.100}", "$description": "Text on solid amber fill." }
      },
      "status": {
        "success-surface":    { "$type": "color", "$value": "{color.success.50}" },
        "success-foreground": { "$type": "color", "$value": "{color.success.700}" },
        "danger-surface":     { "$type": "color", "$value": "{color.danger.50}" },
        "danger-foreground":  { "$type": "color", "$value": "{color.danger.700}" },
        "pending-surface":    { "$type": "color", "$value": "{color.amber.50}" },
        "pending-foreground": { "$type": "color", "$value": "{color.amber.700}" }
      },
      "ring": { "$type": "color", "$value": "rgba(190, 120, 24, 0.32)", "$description": "Focus ring. Amber at 32%." }
    },

    "dark": {
      "$description": "Optional. Inverted neutral mapping with amber held constant. Mostly identical role assignments.",
      "background": {
        "page":    { "$type": "color", "$value": "{color.neutral.950}" },
        "surface": { "$type": "color", "$value": "{color.neutral.900}" },
        "raised":  { "$type": "color", "$value": "{color.neutral.800}" },
        "muted":   { "$type": "color", "$value": "{color.neutral.800}" },
        "inverse": { "$type": "color", "$value": "{color.neutral.100}" }
      },
      "foreground": {
        "default":  { "$type": "color", "$value": "{color.neutral.100}" },
        "muted":    { "$type": "color", "$value": "{color.neutral.400}" },
        "subtle":   { "$type": "color", "$value": "{color.neutral.500}" },
        "disabled": { "$type": "color", "$value": "{color.neutral.600}" },
        "inverse":  { "$type": "color", "$value": "{color.neutral.950}" }
      },
      "border": {
        "default": { "$type": "color", "$value": "{color.neutral.800}" },
        "strong":  { "$type": "color", "$value": "{color.neutral.700}" },
        "subtle":  { "$type": "color", "$value": "{color.neutral.900}" }
      },
      "primary": {
        "default":    { "$type": "color", "$value": "{color.neutral.100}" },
        "hover":      { "$type": "color", "$value": "{color.neutral.200}" },
        "active":     { "$type": "color", "$value": "{color.neutral.300}" },
        "foreground": { "$type": "color", "$value": "{color.neutral.950}" }
      },
      "accent": {
        "default":    { "$type": "color", "$value": "{color.amber.500}" },
        "hover":      { "$type": "color", "$value": "{color.amber.400}" },
        "surface":    { "$type": "color", "$value": "{color.amber.900}" },
        "foreground": { "$type": "color", "$value": "{color.amber.200}" },
        "on-color":   { "$type": "color", "$value": "{color.neutral.950}" }
      },
      "ring": { "$type": "color", "$value": "rgba(232, 177, 76, 0.38)" }
    }
  },

  "typography": {
    "family": {
      "sans": { "$type": "fontFamily", "$value": ["Schibsted Grotesk", "system-ui", "-apple-system", "Segoe UI", "sans-serif"], "$description": "The voice of the brand. Headings, body, marketing, legal." },
      "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "SFMono-Regular", "Menlo", "monospace"], "$description": "The voice of the ledger. Settlement amounts, transaction IDs, timestamps, hashes, account references." }
    },
    "weight": {
      "regular":  { "$type": "fontWeight", "$value": 400 },
      "medium":   { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600, "$description": "Use sparingly. Reserved for display heads that need more weight." }
    },
    "size": {
      "xs":   { "$type": "dimension", "$value": "11px" },
      "sm":   { "$type": "dimension", "$value": "13px" },
      "base": { "$type": "dimension", "$value": "15px", "$description": "Default body. Slightly under 16 for a tighter, more editorial read." },
      "md":   { "$type": "dimension", "$value": "16px" },
      "lg":   { "$type": "dimension", "$value": "18px" },
      "xl":   { "$type": "dimension", "$value": "20px" },
      "2xl":  { "$type": "dimension", "$value": "24px" },
      "3xl":  { "$type": "dimension", "$value": "30px" },
      "4xl":  { "$type": "dimension", "$value": "36px" },
      "5xl":  { "$type": "dimension", "$value": "48px" },
      "6xl":  { "$type": "dimension", "$value": "64px" },
      "7xl":  { "$type": "dimension", "$value": "80px" },
      "8xl":  { "$type": "dimension", "$value": "96px" }
    },
    "tracking": {
      "tight":   { "$type": "dimension", "$value": "-0.02em",  "$description": "Display headings." },
      "snug":    { "$type": "dimension", "$value": "-0.01em",  "$description": "Mid headings, mono numerals at display size." },
      "normal":  { "$type": "dimension", "$value": "0" },
      "wide":    { "$type": "dimension", "$value": "0.08em",   "$description": "Eyebrows, small caps." },
      "widest":  { "$type": "dimension", "$value": "0.14em",   "$description": "Mono eyebrows, system labels." }
    },
    "leading": {
      "tight":   { "$type": "number", "$value": 1.05, "$description": "Display." },
      "snug":    { "$type": "number", "$value": 1.2 },
      "normal":  { "$type": "number", "$value": 1.5, "$description": "Body default." },
      "relaxed": { "$type": "number", "$value": 1.65 }
    }
  },

  "space": {
    "0":   { "$type": "dimension", "$value": "0" },
    "0.5": { "$type": "dimension", "$value": "2px" },
    "1":   { "$type": "dimension", "$value": "4px" },
    "1.5": { "$type": "dimension", "$value": "6px" },
    "2":   { "$type": "dimension", "$value": "8px" },
    "3":   { "$type": "dimension", "$value": "12px" },
    "4":   { "$type": "dimension", "$value": "16px" },
    "5":   { "$type": "dimension", "$value": "20px" },
    "6":   { "$type": "dimension", "$value": "24px" },
    "8":   { "$type": "dimension", "$value": "32px" },
    "10":  { "$type": "dimension", "$value": "40px" },
    "12":  { "$type": "dimension", "$value": "48px" },
    "16":  { "$type": "dimension", "$value": "64px" },
    "20":  { "$type": "dimension", "$value": "80px" },
    "24":  { "$type": "dimension", "$value": "96px" },
    "32":  { "$type": "dimension", "$value": "128px" }
  },

  "radius": {
    "none": { "$type": "dimension", "$value": "0" },
    "xs":   { "$type": "dimension", "$value": "2px" },
    "sm":   { "$type": "dimension", "$value": "4px" },
    "md":   { "$type": "dimension", "$value": "6px" },
    "lg":   { "$type": "dimension", "$value": "8px" },
    "xl":   { "$type": "dimension", "$value": "12px" },
    "2xl":  { "$type": "dimension", "$value": "16px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },

  "shadow": {
    "$description": "The system is mostly flat. Use 0.5px borders before reaching for shadow.",
    "none": { "$type": "shadow", "$value": "none" },
    "sm":   { "$type": "shadow", "$value": "0 1px 0 0 rgba(20, 21, 26, 0.04)" },
    "md":   { "$type": "shadow", "$value": "0 1px 2px rgba(20, 21, 26, 0.06), 0 0 0 0.5px rgba(20, 21, 26, 0.08)" },
    "lg":   { "$type": "shadow", "$value": "0 4px 12px rgba(20, 21, 26, 0.08), 0 0 0 0.5px rgba(20, 21, 26, 0.08)" }
  },

  "motion": {
    "duration": {
      "fast":   { "$type": "duration", "$value": "120ms" },
      "normal": { "$type": "duration", "$value": "200ms" },
      "slow":   { "$type": "duration", "$value": "320ms" }
    },
    "easing": {
      "default": { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] },
      "in":      { "$type": "cubicBezier", "$value": [0.4, 0, 1, 1] },
      "out":     { "$type": "cubicBezier", "$value": [0, 0, 0.2, 1] }
    }
  }
}
